# NAYAK Environment Configuration
# Copy this file to .env
# cp .env.example .env

# ─────────────────────────────────────────
# AI PROVIDER — Choose ONE
# ─────────────────────────────────────────
# ollama = local, free, no API key needed
# gemini = cloud, free, needs API key
NAYAK_PROVIDER=ollama

# ─────────────────────────────────────────
# OLLAMA SETTINGS (Default Provider)
# ─────────────────────────────────────────
# Download Ollama free: https://ollama.com
# Then run: ollama pull llama3.2
# Then run: ollama serve
# No API key needed. Runs on your computer.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─────────────────────────────────────────
# GEMINI SETTINGS (Cloud Option)
# ─────────────────────────────────────────
# Get free key: https://aistudio.google.com
# 1500 requests per day free
# NAYAK_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here

# ─────────────────────────────────────────
# NAYAK SETTINGS
# ─────────────────────────────────────────
NAYAK_HEADLESS=false
